# Netlify: nunca cachear o service worker nem o HTML (senao o app fica preso em versao antiga).
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
/
  Cache-Control: no-cache, no-store, must-revalidate
/manifest.webmanifest
  Cache-Control: no-cache
